# Copy this file to `.env` (in this same directory) and fill in the
# values you have keys for. The gateway will auto-discover .env either
# beside the gateway (llm_gatewayV10/.env) or at the package root
# (S9SharedCode/.env) — first hit wins.
#
# Minimum to run anything: one worker provider + Ollama (for embeddings).
# Minimum to run research-heavy queries (web_search / fetch_url):
# TAVILY_API_KEY (Tavily) or fall back to DuckDuckGo (no key needed —
# the MCP server already handles failover).
#
# You do NOT need all providers. Set the ones you have; the gateway
# fails over through whichever subset is configured.

# ─── Worker providers (the gateway picks among them per request) ──────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

CEREBRAS_API_KEY=
CEREBRAS_MODEL=zai-glm-4.7

NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2

GITHUB_ACCESS_TOKEN=
GITHUB_MODEL=openai/gpt-4.1-mini

OPEN_ROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

OLLAMA_MODEL=
OLLAMA_URL=http://localhost:11434

# ─── Embedding (Ollama default; OpenAI fallback uses OPENAI_API_KEY above) ─
EMBED_OLLAMA_MODEL=nomic-embed-text
# EMBED_FALLBACK_PROVIDER=openai
# EMBED_FALLBACK_MODEL=text-embedding-3-small
# Or: EMBED_FALLBACK_PROVIDER=gemini  EMBED_FALLBACK_MODEL=gemini-embedding-001

# ─── MCP tool keys (orchestrator / code/) ──────────────────────────────────
TAVILY_API_KEY=

# ─── Optional gateway tunables ─────────────────────────────────────────────
# LLM_ORDER=gemini,nvidia,groq,cerebras,openrouter,github,ollama,openai
# ROUTER_ORDER=cerebras,groq,nvidia,github
# GATEWAY_V10_PORT=8110
# LLM_GATEWAY_V10_URL=http://localhost:8110
# Legacy (still honoured): GATEWAY_V9_PORT=8109  LLM_GATEWAY_V9_URL=http://localhost:8109
